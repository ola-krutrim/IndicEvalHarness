# This file will be included in the generated language-specific task configs of generation based evaluations.
# It doesn't have a yaml file extension as it is not meant to be imported directly.
task: null
dataset_path: ai4bharat/IndicSentiment
dataset_name: null
description: "Think and answer.Read the text carefully and determine its sentiment. If the sentiment is positive, answer 0. If the sentiment is negative, answer 1. Put the final answer as Answer: <Answer> where <Answer> is 0/1."
test_split: test
dataset_kwargs:
  trust_remote_code: True
output_type: generate_until
doc_to_text: null
doc_to_target: !function utils.doc_to_target
generation_kwargs:
  until:
    - "</s>"
filter_list:
- name: "normalize-labels"
  filter:
  - function: regex
    regex_pattern: "Answer\\s*:\\s*([0-1])"
  - function: take_first
metric_list:
  - metric: exact_match
    aggregation: mean
    higher_is_better: True
metadata:
  version: 1.0
