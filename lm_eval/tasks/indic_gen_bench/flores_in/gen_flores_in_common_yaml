# This file will be included in the generated language-specific task configs of generation based evaluations.
# It doesn't have a yaml file extension as it is not meant to be imported directly.
task: null
dataset_path: google/IndicGenBench_flores_in
dataset_name: null
description: "Directly start your answer with the translation and only output the translation and nothing else. You are given few shot examples to help you respond.\nTranslate the following:\n\n"
validation_split: validation
test_split: test
dataset_kwargs:
  field: 'examples'
  trust_remote_code: True
output_type: generate_until
fewshot_split: validation
num_fewshot: 1
doc_to_text: !function utils.doc_to_text
doc_to_target: target
generation_kwargs:
  until:
    - "\n\n"
    - "</s>"
  max_new_tokens: 1024
metric_list:
  - metric: chrf
    aggregation: chrf
    higher_is_better: true
metadata:
  version: 1.0
