# This file will be included in the generated language-specific task configs of generation based evaluations.
# It doesn't have a yaml file extension as it is not meant to be imported directly.
task: null
dataset_path: sarvamai/boolq-indic
dataset_name: null
description: "Think and answer. Read the text carefully and determine the correct alternative. If the answer to the question is no then return 0, if the answer to the question is yes then return 1. Put the final answer as Answer: <Answer> where <Answer> is 0/1."
test_split: validation
validation_split: train
fewshot_split: train
dataset_kwargs:
  trust_remote_code: True
output_type: generate_until
doc_to_text: !function utils.doc_to_text
doc_to_target: label
generation_kwargs:
  max_gen_toks: 2048
  until:
    - "</s>"
filter_list:
- name: "normalize-labels"
  filter:
  - function: regex
    regex_pattern: "Answer\\s*:\\s*([0-1])"
  - function: take_first
metric_list:
  - metric: exact_match
    aggregation: mean
    higher_is_better: True
metadata:
  version: 1.0
